# ===========================================
# The CTO's Morning Brief — Environment Config
# ===========================================

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/newsletter_db

# ---- Redis (Celery Broker) ----
REDIS_URL=redis://localhost:6379/0

# ---- Gemini AI ----
GEMINI_API_KEY=your-gemini-api-key-here

# ---- FastAPI ----
APP_ENV=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
FEED_SYNC_INTERVAL_HOURS=2
